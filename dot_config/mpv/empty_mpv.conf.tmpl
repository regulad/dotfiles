# Generated in parts by Claude Sonnet 4.6

##############################
# Tvheadend stream resilience (all platforms)
##############################
cache=yes
demuxer-readahead-secs=5
network-timeout=10
keep-open=yes
stream-lavf-o-add=reconnect=1
stream-lavf-o-add=reconnect_streamed=1
#stream-lavf-o-add=reconnect_at_eof=1
#stream-lavf-o-add=reconnect_delay_max=5
demuxer-lavf-o=fflags=+genpts

##############################
# Filtering
##############################
scale=ewa_lanczos4sharpest
cscale=ewa_lanczos4sharpest
dscale=ewa_lanczos4sharpest

scale-antiring=0.7
cscale-antiring=0.7
dscale-antiring=0.7

sigmoid-upscaling=yes
correct-downscaling=yes
linear-downscaling=yes

##############################
# Bit depth
##############################
fbo-format=rgba16hf
dither-depth=auto
dither=error-diffusion
error-diffusion=sierra-lite

##############################
# Frame timecode display
##############################
osd-status-msg=${time-pos} / ${duration}  ${user-data/frame-padded}  ${user-data/timecode-approx}

##############################
# Misc.
##############################
loop=inf

##############################
# Platform-specific decode / render / deinterlace
##############################
{{- if eq .chezmoi.os "linux" }}
vo=gpu
gpu-api=vulkan
hwdec=vaapi
hwdec-codecs=all
vf-pre=vavpp:deint=weave:interlaced-only=yes
{{- else if eq .chezmoi.os "windows" }}
vo=gpu-next
gpu-api=vulkan
hwdec=vulkan-copy
hwdec-codecs=all
vf-pre=bwdif=mode=1:parity=-1:deint=1
{{- else if eq .chezmoi.os "darwin" }}
vo=gpu-next
gpu-api=vulkan
hwdec=videotoolbox-copy
hwdec-codecs=all
vf-pre=bwdif=mode=1:parity=-1:deint=1
{{- end }}

[downmix-ac4-style]
profile-cond=p["audio-params/channel-count"] > 2
profile-restore=copy
audio-channels=stereo
audio-normalize-downmix=no
af-add=lavfi=[pan=stereo|FL=FL+0.707*FC+0.707*BL+0.707*SL|FR=FR+0.707*FC+0.707*BR+0.707*SR,loudnorm=I=-16:LRA=11:TP=-1.5,alimiter=limit=0.891:attack=5:release=50:level=disabled]

[mpeg2-deartifact]
profile-cond=video_format == "mpeg2video"
vf-add=pp=hb/vb/dr/al:autoq
vf-add=nlmeans=s=3:p=7:r=15
vf-add=gradfun=3.0:16

{{- if not .useDummySecrets }}
{{- $bw := bitwarden "item" "tvheadend-livingston" }}
[tvheadend-livingston-auth]
profile-cond=(string.find(get("stream-open-filename") or "", "tvheadend%.regulad%-verizon%-livingston%.internal:9981") ~= nil) or (string.find(get("stream-open-filename") or "", "tvheadend%-livingston%.regulad%.xyz") ~= nil)
http-header-fields=Authorization: Basic {{ printf "%s:%s" $bw.login.username $bw.login.password | b64enc }}
{{- end }}
