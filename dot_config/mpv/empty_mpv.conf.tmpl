# Generated in parts by Claude Sonnet 4.6

##############################
# Tvheadend stream resilience (all platforms)
##############################
cache=yes
demuxer-readahead-secs=5
network-timeout=10
demuxer-lavf-o=fflags=+genpts

##############################
# Platform-specific decode / render / deinterlace
##############################
{{- if eq .chezmoi.os "linux" }}
# Linux: VAAPI decode + Vulkan render. hwdec stays vaapi (not the newer vulkan
# hwdec) because vavpp's hardware weave deinterlace operates on VAAPI surfaces —
# there's no equivalent deinterlace path for the native Vulkan decoder yet.
# vo=gpu (not gpu-next) because vavpp's documented compatibility list is
# vo=vaapi/gpu specifically; worth testing gpu-next too, just not guaranteed.
vo=gpu
gpu-api=vulkan
hwdec=vaapi
hwdec-codecs=all

[deinterlace]
vf=vavpp:deint=weave:interlaced-only=no

{{- else if eq .chezmoi.os "windows" }}
# Windows: D3D11 decode/render. d3d11vpp (the D3D11 hardware deinterlace filter)
# has a history of failing to load on some driver/mpv combos, so this falls back
# to software bwdif, which needs the frame copied back from VRAM to system RAM.
# Note this isn't literal weave — bwdif is motion-adaptive — but it's the
# reliable cross-driver option.
vo=gpu-next
gpu-api=d3d11
hwdec=d3d11va-copy
hwdec-codecs=all

[deinterlace]
profile-cond=p["video-frame-info/tff"] or p["video-frame-info/interlaced"]
profile-restore=copy
vf=d3d11vpp=deint=yes:interlaced-only=yes

{{- else if eq .chezmoi.os "darwin" }}
# macOS: decode must stay on VideoToolbox — Vulkan is only available via
# MoltenVK, which doesn't expose hardware video decode extensions and isn't
# expected to. Render uses Vulkan anyway, since libplacebo has no native Metal
# backend and Apple deprecated OpenGL; MoltenVK translates Vulkan to Metal.
# Same CPU-copy caveat as Windows for deinterlacing.
vo=gpu-next
gpu-api=vulkan
hwdec=videotoolbox-copy
hwdec-codecs=all

[deinterlace]
vf=bwdif=mode=send_field:deint=all
{{- end }}
