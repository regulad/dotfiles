# Generated in parts by Claude Sonnet 4.6

##############################
# Tvheadend stream resilience (all platforms)
##############################
cache=yes
demuxer-readahead-secs=5
network-timeout=10
keep-open=yes
stream-disconnect-retry-count=infinite
demuxer-lavf-o=fflags=+genpts

##############################
# Platform-specific decode / render / deinterlace
##############################
{{- if eq .chezmoi.os "linux" }}
vo=gpu
gpu-api=vulkan
hwdec=vaapi
hwdec-codecs=all

[deinterlace]
vf=vavpp:deint=weave:interlaced-only=yes

{{- else if eq .chezmoi.os "windows" }}
vo=gpu-next
gpu-api=d3d11
hwdec=d3d11va-copy
hwdec-codecs=all

[deinterlace]
profile-cond=p["video-frame-info/tff"] or p["video-frame-info/interlaced"]
profile-restore=copy
vf=d3d11vpp=deint=yes:interlaced-only=yes

{{- else if eq .chezmoi.os "darwin" }}
vo=gpu-next
gpu-api=vulkan
hwdec=videotoolbox-copy
hwdec-codecs=all

[deinterlace]
vf=bwdif=mode=send_field:deint=all
{{- end }}

[downmix-ac4-style]
profile-cond=p["audio-params/channel-count"] > 2
profile-restore=copy
audio-channels=stereo
audio-normalize-downmix=no
af=lavfi=[pan=stereo|FL=FL+0.707*FC+0.707*BL+0.707*SL|FR=FR+0.707*FC+0.707*BR+0.707*SR,loudnorm=I=-16:LRA=11:TP=-1.5]
