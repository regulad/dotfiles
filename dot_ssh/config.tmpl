# Configuration
Include config.d/*

IgnoreUnknown WarnWeakCrypto,UseKeychain
AddKeysToAgent yes
HashKnownHosts yes
VerifyHostKeyDNS yes

Host *
  EnableEscapeCommandline yes

# Hardware hosts
Host prodingus
    HostName prodingus.tail11540.ts.net
    User root
{{- if not .useDummySecrets }}
    IdentityFile ~/.ssh/id_rsa3072.pub
    IdentityFile ~/.ssh/id_rsa3072  # fallback
{{- end }}
    IdentitiesOnly yes
    ForwardAgent yes

Host turk
    HostName turk.tail11540.ts.net
    ForwardAgent yes

# Embedded
Host JPE18280417
    # Arista 7010T-48 Switch
    WarnWeakCrypto no
    HostName jpe18280417.regulad-verizon-livingston.internal
    User regulad
{{- if not .useDummySecrets }}
    IdentityFile ~/.ssh/id_rsa4096.pub
    IdentityFile ~/.ssh/id_rsa4096  # fallback
{{- end }}
    IdentitiesOnly yes

Host switch45f304
    # Cisco SG300-10 Switch
    # WARNING! Does not support PQ nor SHA256
    WarnWeakCrypto no
    HostName switch45f304.regulad-verizon-livingston.internal
