# Configuration
Include config.d/*

IgnoreUnknown WarnWeakCrypto,UseKeychain
AddKeysToAgent yes
HashKnownHosts yes
VerifyHostKeyDNS yes

Host *
  EnableEscapeCommandline yes

# Hardware hosts
Host prodingus
    HostName prodingus.tail11540.ts.net
    User root
{{- if not .useDummySecrets }}
    IdentityFile ~/.ssh/id_rsa3072.pub
    IdentityFile ~/.ssh/id_rsa3072  # fallback
{{- end }}
    IdentitiesOnly yes
    ForwardAgent yes

Host turk
    HostName turk.tail11540.ts.net
